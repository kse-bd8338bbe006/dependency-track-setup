        "datasource": { "type": "grafana-postgresql-datasource", "uid": "P0DBEC7308BC872CD" },
        "editorMode": "code", "format": "table", "rawQuery": true,
        "rawSql": "WITH latest_project AS (\n  SELECT DISTINCT ON (p.\"NAME\") p.\"ID\", p.\"NAME\", p.\"VERSION\"\n  FROM \"PROJECT\" p\n  WHERE ('${project:raw}' = '$__all' OR p.\"NAME\" IN (${project:sqlstring}))\n  ORDER BY p.\"NAME\", p.\"LAST_BOM_IMPORTED\" DESC NULLS LAST\n)\nSELECT\n  v.\"VULNID\" AS vuln_id,\n  v.\"SEVERITY\" AS severity,\n  COALESCE(v.\"CVSSV3BASESCORE\", v.\"CVSSV2BASESCORE\", 0) AS cvss,\n  COALESCE(v.\"EPSSSCORE\", 0) AS epss,\n  COALESCE(v.\"EPSSPERCENTILE\", 0) AS epss_percentile,\n  c.\"NAME\" AS component,\n  c.\"VERSION\" AS version,\n  lp.\"NAME\" AS project,\n  EXTRACT(DAY FROM NOW() - fa.\"ATTRIBUTED_ON\")::int AS age_days,\n  COALESCE(a.\"STATE\", 'NOT_SET') AS analysis_state\nFROM latest_project lp\nJOIN \"FINDINGATTRIBUTION\" fa ON fa.\"PROJECT_ID\" = lp.\"ID\"\nJOIN \"VULNERABILITY\" v ON v.\"ID\" = fa.\"VULNERABILITY_ID\"\nJOIN \"COMPONENT\" c ON c.\"ID\" = fa.\"COMPONENT_ID\"\nLEFT JOIN \"ANALYSIS\" a ON a.\"COMPONENT_ID\" = fa.\"COMPONENT_ID\" AND a.\"VULNERABILITY_ID\" = fa.\"VULNERABILITY_ID\" AND a.\"PROJECT_ID\" = lp.\"ID\"\nWHERE (a.\"STATE\" IS NULL OR a.\"STATE\" NOT IN ('RESOLVED','FALSE_POSITIVE','NOT_AFFECTED'))\nORDER BY COALESCE(v.\"EPSSSCORE\", 0) DESC, v.\"SEVERITY\" ASC\nLIMIT 100",
        "refId": "A"
      }]
