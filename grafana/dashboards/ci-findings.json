        "rawSql": "WITH latest_project AS (\n  SELECT DISTINCT ON (p.\"NAME\") p.\"ID\", p.\"NAME\"\n  FROM \"PROJECT\" p\n  WHERE ('${project:raw}' = '$__all' OR p.\"NAME\" IN (${project:sqlstring}))\n  ORDER BY p.\"NAME\", p.\"LAST_BOM_IMPORTED\" DESC NULLS LAST\n)\nSELECT\n  lp.\"NAME\" AS project,\n  pm.\"FINDINGS_TOTAL\" AS total_findings,\n  pm.\"FINDINGS_AUDITED\" AS audited,\n  pm.\"FINDINGS_UNAUDITED\" AS unaudited,\n  CASE WHEN pm.\"FINDINGS_TOTAL\" > 0 THEN pm.\"FINDINGS_AUDITED\"::float / pm.\"FINDINGS_TOTAL\" ELSE 0 END AS triage_pct\nFROM latest_project lp\nJOIN \"PROJECTMETRICS\" pm ON pm.\"PROJECT_ID\" = lp.\"ID\"\n  AND pm.\"LAST_OCCURRENCE\" = (SELECT MAX(pm2.\"LAST_OCCURRENCE\") FROM \"PROJECTMETRICS\" pm2 WHERE pm2.\"PROJECT_ID\" = lp.\"ID\")\nWHERE pm.\"FINDINGS_TOTAL\" > 0\nORDER BY CASE WHEN pm.\"FINDINGS_TOTAL\" > 0 THEN pm.\"FINDINGS_AUDITED\"::float / pm.\"FINDINGS_TOTAL\" ELSE 0 END ASC",
