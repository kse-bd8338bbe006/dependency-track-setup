      "title": "CI Build Gate Status by Project",
      "type": "table",
      "targets": [{
        "datasource": { "type": "grafana-postgresql-datasource", "uid": "P0DBEC7308BC872CD" },
        "editorMode": "code", "format": "table", "rawQuery": true,
        "rawSql": "WITH latest_project AS (\n  SELECT DISTINCT ON (p.\"NAME\") p.\"ID\", p.\"NAME\", p.\"VERSION\", p.\"UUID\", p.\"LAST_BOM_IMPORTED\"\n  FROM \"PROJECT\" p\n  WHERE ('${project:raw}' = '$__all' OR p.\"NAME\" IN (${project:sqlstring}))\n  ORDER BY p.\"NAME\", p.\"LAST_BOM_IMPORTED\" DESC NULLS LAST\n)\nSELECT\n  lp.\"NAME\" AS project,\n  lp.\"VERSION\" AS version,\n  lp.\"UUID\" AS project_uuid,\n  CASE\n    WHEN pm.\"CRITICAL\" > 0 THEN 'BLOCKED'\n    WHEN pm.\"HIGH\" > 5 THEN 'WARNING'\n    ELSE 'PASS'\n  END AS build_status,\n  pm.\"RISKSCORE\" AS risk_score,\n  pm.\"CRITICAL\" AS critical,\n  pm.\"HIGH\" AS high,\n  pm.\"MEDIUM\" AS medium,\n  pm.\"LOW\" AS low,\n  COALESCE((\n    SELECT MAX(v.\"EPSSSCORE\")\n    FROM \"FINDINGATTRIBUTION\" fa\n    JOIN \"VULNERABILITY\" v ON v.\"ID\" = fa.\"VULNERABILITY_ID\"\n    LEFT JOIN \"ANALYSIS\" a ON a.\"COMPONENT_ID\" = fa.\"COMPONENT_ID\" AND a.\"VULNERABILITY_ID\" = fa.\"VULNERABILITY_ID\" AND a.\"PROJECT_ID\" = lp.\"ID\"\n    WHERE fa.\"PROJECT_ID\" = lp.\"ID\"\n      AND (a.\"STATE\" IS NULL OR a.\"STATE\" NOT IN ('RESOLVED','FALSE_POSITIVE','NOT_AFFECTED'))\n  ), 0) AS max_epss,\n  pm.\"COMPONENTS\" AS components,\n  lp.\"LAST_BOM_IMPORTED\" AS last_scan\nFROM latest_project lp\nJOIN \"PROJECTMETRICS\" pm ON pm.\"PROJECT_ID\" = lp.\"ID\"\n  AND pm.\"LAST_OCCURRENCE\" = (SELECT MAX(pm2.\"LAST_OCCURRENCE\") FROM \"PROJECTMETRICS\" pm2 WHERE pm2.\"PROJECT_ID\" = lp.\"ID\")\nORDER BY pm.\"RISKSCORE\" DESC",
        "refId": "A"
      }]
    },

