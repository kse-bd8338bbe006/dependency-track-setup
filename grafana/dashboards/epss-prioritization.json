      "title": "Vulnerabilities Prioritized by EPSS Score",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "P0DBEC7308BC872CD" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  v.\"VULNID\" AS vuln_id,\n  v.\"SEVERITY\" AS severity,\n  ROUND(CAST(v.\"EPSSSCORE\" AS numeric), 5) AS epss_score,\n  ROUND(CAST(v.\"EPSSPERCENTILE\" AS numeric), 5) AS epss_percentile,\n  v.\"CVSSV3BASESCORE\" AS cvss_v3,\n  p.\"NAME\" AS project,\n  p.\"VERSION\" AS version,\n  c.\"NAME\" AS component,\n  c.\"VERSION\" AS component_version,\n  CASE\n    WHEN v.\"EPSSSCORE\" > 0.1 THEN 'CRITICAL'\n    WHEN v.\"EPSSSCORE\" > 0.05 THEN 'HIGH'\n    WHEN v.\"EPSSSCORE\" > 0.01 THEN 'MEDIUM'\n    ELSE 'LOW'\n  END AS priority,\n  v.\"PUBLISHED\" AS published\nFROM \"VULNERABILITY\" v\nJOIN \"COMPONENTS_VULNERABILITIES\" cv ON cv.\"VULNERABILITY_ID\" = v.\"ID\"\nJOIN \"COMPONENT\" c ON c.\"ID\" = cv.\"COMPONENT_ID\"\nJOIN \"PROJECT\" p ON p.\"ID\" = c.\"PROJECT_ID\"\nWHERE v.\"EPSSSCORE\" IS NOT NULL\n  AND ('${project:raw}' = '$__all' OR p.\"NAME\" || ':' || p.\"VERSION\" IN (${project:sqlstring}))\nORDER BY v.\"EPSSSCORE\" DESC",
          "refId": "A"
        }
      ]
    },
