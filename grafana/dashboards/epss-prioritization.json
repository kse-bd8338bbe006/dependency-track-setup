          "rawQuery": true,
          "rawSql": "SELECT\n  CASE\n    WHEN v.\"EPSSSCORE\" > 0.1 THEN 'CRITICAL'\n    WHEN v.\"EPSSSCORE\" > 0.05 THEN 'HIGH'\n    WHEN v.\"EPSSSCORE\" > 0.01 THEN 'MEDIUM'\n    ELSE 'LOW'\n  END AS priority,\n  COUNT(*) AS count\nFROM \"VULNERABILITY\" v\nJOIN \"COMPONENTS_VULNERABILITIES\" cv ON cv.\"VULNERABILITY_ID\" = v.\"ID\"\nJOIN \"COMPONENT\" c ON c.\"ID\" = cv.\"COMPONENT_ID\"\nJOIN \"PROJECT\" p ON p.\"ID\" = c.\"PROJECT_ID\"\nWHERE v.\"EPSSSCORE\" IS NOT NULL\n  AND ('${project:raw}' = '$__all' OR p.\"NAME\" || ':' || p.\"VERSION\" IN (${project:sqlstring}))\nGROUP BY priority\nORDER BY count DESC",
