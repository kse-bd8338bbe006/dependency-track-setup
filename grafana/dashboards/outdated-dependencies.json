      "title": "Outdated Dependencies Detail",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "P0DBEC7308BC872CD" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  c.\"NAME\" AS component,\n  COALESCE(c.\"GROUP\", '') AS group,\n  c.\"VERSION\" AS current_version,\n  rmc.\"LATEST_VERSION\" AS latest_version,\n  rmc.\"REPOSITORY_TYPE\" AS ecosystem,\n  CASE\n    WHEN split_part(c.\"VERSION\", '.', 1) ~ '^[0-9]+$' AND split_part(rmc.\"LATEST_VERSION\", '.', 1) ~ '^[0-9]+$'\n    THEN split_part(rmc.\"LATEST_VERSION\", '.', 1)::int - split_part(c.\"VERSION\", '.', 1)::int\n    ELSE NULL\n  END AS major_behind,\n  p.\"NAME\" || ':' || p.\"VERSION\" AS project,\n  (SELECT COUNT(*) FROM \"COMPONENTS_VULNERABILITIES\" cv WHERE cv.\"COMPONENT_ID\" = c.\"ID\") AS vulnerabilities,\n  rmc.\"PUBLISHED\" AS latest_published\nFROM \"COMPONENT\" c\nJOIN \"PROJECT\" p ON p.\"ID\" = c.\"PROJECT_ID\"\nJOIN \"REPOSITORY_META_COMPONENT\" rmc ON rmc.\"NAME\" = c.\"NAME\" AND COALESCE(rmc.\"NAMESPACE\",'') = COALESCE(c.\"GROUP\",'')\nWHERE c.\"VERSION\" != rmc.\"LATEST_VERSION\"\n  AND ('${project:raw}' = '$__all' OR p.\"NAME\" || ':' || p.\"VERSION\" IN (${project:sqlstring}))\nORDER BY major_behind DESC NULLS LAST, c.\"NAME\"",
          "refId": "A"
        }
      ]
    }
