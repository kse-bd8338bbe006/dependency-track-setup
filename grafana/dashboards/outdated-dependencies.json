        "rawQuery": true,
        "rawSql": "SELECT status, count FROM (\n  SELECT 'Outdated' AS status, COUNT(*) AS count, 1 AS sort\n  FROM \"COMPONENT\" c\n  JOIN \"PROJECT\" p ON p.\"ID\" = c.\"PROJECT_ID\"\n  JOIN \"REPOSITORY_META_COMPONENT\" rmc ON rmc.\"NAME\" = c.\"NAME\" AND COALESCE(rmc.\"NAMESPACE\",'') = COALESCE(c.\"GROUP\",'')\n  WHERE c.\"VERSION\" != rmc.\"LATEST_VERSION\"\n    AND ('${project:raw}' = '$__all' OR p.\"NAME\" || ':' || p.\"VERSION\" IN (${project:sqlstring}))\n  UNION ALL\n  SELECT 'Up to Date' AS status, COUNT(*) AS count, 2 AS sort\n  FROM \"COMPONENT\" c\n  JOIN \"PROJECT\" p ON p.\"ID\" = c.\"PROJECT_ID\"\n  JOIN \"REPOSITORY_META_COMPONENT\" rmc ON rmc.\"NAME\" = c.\"NAME\" AND COALESCE(rmc.\"NAMESPACE\",'') = COALESCE(c.\"GROUP\",'')\n  WHERE c.\"VERSION\" = rmc.\"LATEST_VERSION\"\n    AND ('${project:raw}' = '$__all' OR p.\"NAME\" || ':' || p.\"VERSION\" IN (${project:sqlstring}))\n  UNION ALL\n  SELECT 'No Metadata' AS status, COUNT(*) AS count, 3 AS sort\n  FROM \"COMPONENT\" c\n  JOIN \"PROJECT\" p ON p.\"ID\" = c.\"PROJECT_ID\"\n  LEFT JOIN \"REPOSITORY_META_COMPONENT\" rmc ON rmc.\"NAME\" = c.\"NAME\" AND COALESCE(rmc.\"NAMESPACE\",'') = COALESCE(c.\"GROUP\",'')\n  WHERE rmc.\"ID\" IS NULL\n    AND ('${project:raw}' = '$__all' OR p.\"NAME\" || ':' || p.\"VERSION\" IN (${project:sqlstring}))\n) sub ORDER BY sort",
