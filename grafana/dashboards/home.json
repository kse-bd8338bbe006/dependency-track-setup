      "title": "SLA Breached",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "grafana-postgresql-datasource", "uid": "P0DBEC7308BC872CD" },
        "editorMode": "code", "format": "table", "rawQuery": true,
        "rawSql": "SELECT COUNT(*) AS count FROM \"FINDINGATTRIBUTION\" fa JOIN \"VULNERABILITY\" v ON v.\"ID\" = fa.\"VULNERABILITY_ID\" JOIN \"COMPONENT\" c ON c.\"ID\" = fa.\"COMPONENT_ID\" LEFT JOIN \"ANALYSIS\" a ON a.\"COMPONENT_ID\" = fa.\"COMPONENT_ID\" AND a.\"VULNERABILITY_ID\" = fa.\"VULNERABILITY_ID\" AND a.\"PROJECT_ID\" = c.\"PROJECT_ID\" WHERE (a.\"STATE\" IS NULL OR a.\"STATE\" NOT IN ('RESOLVED','FALSE_POSITIVE','NOT_AFFECTED')) AND EXTRACT(DAY FROM NOW() - fa.\"ATTRIBUTED_ON\") > CASE v.\"SEVERITY\" WHEN 'CRITICAL' THEN 7 WHEN 'HIGH' THEN 30 WHEN 'MEDIUM' THEN 90 WHEN 'LOW' THEN 180 ELSE 180 END",
        "refId": "A"
