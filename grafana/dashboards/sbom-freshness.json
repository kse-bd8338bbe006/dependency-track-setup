        "datasource": { "type": "grafana-postgresql-datasource", "uid": "P0DBEC7308BC872CD" },
        "editorMode": "code", "format": "table", "rawQuery": true,
        "rawSql": "SELECT status, count FROM (\n  SELECT 'Fresh' AS status, COUNT(*) AS count, 1 AS sort\n  FROM \"PROJECT\" WHERE \"ACTIVE\" = true AND \"LAST_BOM_IMPORTED\" >= NOW() - ($fresh_days || ' days')::interval\n  UNION ALL\n  SELECT 'Stale' AS status, COUNT(*) AS count, 2 AS sort\n  FROM \"PROJECT\" WHERE \"ACTIVE\" = true AND \"LAST_BOM_IMPORTED\" < NOW() - ($fresh_days || ' days')::interval AND \"LAST_BOM_IMPORTED\" >= NOW() - ($stale_days || ' days')::interval\n  UNION ALL\n  SELECT 'Critical' AS status, COUNT(*) AS count, 3 AS sort\n  FROM \"PROJECT\" WHERE \"ACTIVE\" = true AND \"LAST_BOM_IMPORTED\" < NOW() - ($stale_days || ' days')::interval\n) sub ORDER BY sort",
        "refId": "A"
