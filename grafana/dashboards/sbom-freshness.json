      "title": "Project Scan Status",
      "type": "table",
      "targets": [{
        "datasource": { "type": "grafana-postgresql-datasource", "uid": "P0DBEC7308BC872CD" },
        "editorMode": "code", "format": "table", "rawQuery": true,
        "rawSql": "SELECT\n  p.\"NAME\" || ':' || p.\"VERSION\" AS project,\n  p.\"CLASSIFIER\" AS classifier,\n  EXTRACT(DAY FROM NOW() - p.\"LAST_BOM_IMPORTED\")::int AS days_since_scan,\n  CASE\n    WHEN p.\"LAST_BOM_IMPORTED\" >= NOW() - ($fresh_days || ' days')::interval THEN 'Fresh'\n    WHEN p.\"LAST_BOM_IMPORTED\" >= NOW() - ($stale_days || ' days')::interval THEN 'Stale'\n    ELSE 'Critical'\n  END AS freshness,\n  (SELECT COUNT(*) FROM \"COMPONENT\" c WHERE c.\"PROJECT_ID\" = p.\"ID\") AS components,\n  (SELECT COUNT(DISTINCT cv.\"VULNERABILITY_ID\") FROM \"COMPONENT\" c2 JOIN \"COMPONENTS_VULNERABILITIES\" cv ON cv.\"COMPONENT_ID\" = c2.\"ID\" WHERE c2.\"PROJECT_ID\" = p.\"ID\") AS vulnerabilities,\n  (SELECT COUNT(*) FROM \"BOM\" b WHERE b.\"PROJECT_ID\" = p.\"ID\") AS sbom_uploads,\n  p.\"LAST_BOM_IMPORTED\" AS last_scan,\n  p.\"LAST_VULNERABILITY_ANALYSIS\" AS last_vuln_analysis\nFROM \"PROJECT\" p\nWHERE p.\"ACTIVE\" = true\nORDER BY days_since_scan DESC",
        "refId": "A"
      }]
    },

