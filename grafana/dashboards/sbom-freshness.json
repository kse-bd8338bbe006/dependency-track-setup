      "title": "SBOM Upload History",
      "type": "table",
      "targets": [{
        "datasource": { "type": "grafana-postgresql-datasource", "uid": "P0DBEC7308BC872CD" },
        "editorMode": "code", "format": "table", "rawQuery": true,
        "rawSql": "SELECT\n  p.\"NAME\" || ':' || p.\"VERSION\" AS project,\n  b.\"BOM_FORMAT\" AS format,\n  b.\"SPEC_VERSION\" AS spec_version,\n  b.\"SERIAL_NUMBER\" AS serial_number,\n  b.\"IMPORTED\" AS imported,\n  CASE\n    WHEN b.\"IMPORTED\" >= NOW() - ($fresh_days || ' days')::interval THEN 'Fresh'\n    WHEN b.\"IMPORTED\" >= NOW() - ($stale_days || ' days')::interval THEN 'Stale'\n    ELSE 'Critical'\n  END AS freshness\nFROM \"BOM\" b\nJOIN \"PROJECT\" p ON p.\"ID\" = b.\"PROJECT_ID\"\nORDER BY b.\"IMPORTED\" DESC",
        "refId": "A"
      }]
