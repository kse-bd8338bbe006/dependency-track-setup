      "title": "Components with license: $license",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "P0DBEC7308BC872CD" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  c.\"NAME\" AS component,\n  c.\"VERSION\" AS version,\n  COALESCE(c.\"GROUP\", '') AS group,\n  COALESCE(c.\"PURL\", '') AS purl,\n  p.\"NAME\" || ':' || p.\"VERSION\" AS project,\n  c.\"CLASSIFIER\" AS classifier,\n  (SELECT COUNT(*) FROM \"COMPONENTS_VULNERABILITIES\" cv WHERE cv.\"COMPONENT_ID\" = c.\"ID\") AS vulnerabilities\nFROM \"COMPONENT\" c\nLEFT JOIN \"LICENSE\" l ON l.\"ID\" = c.\"LICENSE_ID\"\nJOIN \"PROJECT\" p ON p.\"ID\" = c.\"PROJECT_ID\"\nWHERE COALESCE(l.\"NAME\", c.\"LICENSE\", 'Unknown') = '${license}'\n  AND ('${project:raw}' = '$__all' OR p.\"NAME\" || ':' || p.\"VERSION\" IN (${project:sqlstring}))\nORDER BY c.\"NAME\", c.\"VERSION\"",
          "refId": "A"
        }
      ]
