      "title": "License Group",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "grafana-postgresql-datasource", "uid": "P0DBEC7308BC872CD" },
        "editorMode": "code",
        "format": "table",
        "rawQuery": true,
        "rawSql": "SELECT COALESCE(\n  (SELECT lg.\"NAME\" FROM \"LICENSEGROUP\" lg JOIN \"LICENSEGROUP_LICENSE\" lgl ON lgl.\"LICENSEGROUP_ID\" = lg.\"ID\" WHERE lgl.\"LICENSE_ID\" = l.\"ID\" LIMIT 1),\n  'Unknown'\n) AS license_group\nFROM \"COMPONENT\" c\nLEFT JOIN \"LICENSE\" l ON l.\"ID\" = c.\"LICENSE_ID\"\nWHERE COALESCE(l.\"NAME\", c.\"LICENSE\", 'Unknown') = '${license}'\nLIMIT 1",
        "refId": "A"
