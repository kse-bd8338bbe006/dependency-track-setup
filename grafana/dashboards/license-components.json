        "editorMode": "code",
        "format": "table",
        "rawQuery": true,
        "rawSql": "SELECT COUNT(*) AS count\nFROM \"COMPONENT\" c\nLEFT JOIN \"LICENSE\" l ON l.\"ID\" = c.\"LICENSE_ID\"\nJOIN \"PROJECT\" p ON p.\"ID\" = c.\"PROJECT_ID\"\nWHERE COALESCE(l.\"NAME\", c.\"LICENSE\", 'Unknown') = '${license}'\n  AND ('${project:raw}' = '$__all' OR p.\"NAME\" || ':' || p.\"VERSION\" IN (${project:sqlstring}))",
        "refId": "A"
      }]
    },
