        "editorMode": "code", "format": "table", "rawQuery": true,
        "rawSql": "SELECT SUM(sub.risk)::int AS score FROM (\n  SELECT DISTINCT ON (p.\"ID\") pm.\"RISKSCORE\" AS risk\n  FROM \"PROJECT\" p\n  JOIN \"PROJECTMETRICS\" pm ON pm.\"PROJECT_ID\" = p.\"ID\"\n  WHERE p.\"ACTIVE\" = true\n    AND ('${project:raw}' = '$__all' OR p.\"NAME\" || ':' || p.\"VERSION\" IN (${project:sqlstring}))\n  ORDER BY p.\"ID\", pm.\"LAST_OCCURRENCE\" DESC\n) sub",
