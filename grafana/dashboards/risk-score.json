      "title": "Risk Score Breakdown by Project",
      "type": "barchart",
      "targets": [{
        "datasource": { "type": "grafana-postgresql-datasource", "uid": "P0DBEC7308BC872CD" },
        "editorMode": "code", "format": "table", "rawQuery": true,
        "rawSql": "SELECT\n  p.\"NAME\" || ':' || p.\"VERSION\" AS project,\n  pm.\"CRITICAL\" * 10 AS \"Critical (×10)\",\n  pm.\"HIGH\" * 5 AS \"High (×5)\",\n  pm.\"MEDIUM\" * 3 AS \"Medium (×3)\",\n  pm.\"LOW\" * 1 AS \"Low (×1)\",\n  COALESCE(pm.\"UNASSIGNED_SEVERITY\", 0) * 5 AS \"Unassigned (×5)\"\nFROM \"PROJECT\" p\nJOIN \"PROJECTMETRICS\" pm ON pm.\"PROJECT_ID\" = p.\"ID\"\nWHERE p.\"ACTIVE\" = true\n  AND ('${project:raw}' = '$__all' OR p.\"NAME\" || ':' || p.\"VERSION\" IN (${project:sqlstring}))\n  AND pm.\"LAST_OCCURRENCE\" = (\n    SELECT MAX(pm2.\"LAST_OCCURRENCE\") FROM \"PROJECTMETRICS\" pm2 WHERE pm2.\"PROJECT_ID\" = p.\"ID\"\n  )\nORDER BY pm.\"RISKSCORE\" DESC",
        "refId": "A"
      }]
