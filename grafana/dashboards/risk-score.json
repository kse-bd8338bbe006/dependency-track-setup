      "title": "Project Risk Detail",
      "type": "table",
      "targets": [{
        "datasource": { "type": "grafana-postgresql-datasource", "uid": "P0DBEC7308BC872CD" },
        "editorMode": "code", "format": "table", "rawQuery": true,
        "rawSql": "SELECT\n  p.\"NAME\" || ':' || p.\"VERSION\" AS project,\n  pm.\"RISKSCORE\"::int AS risk_score,\n  pm.\"CRITICAL\" AS critical,\n  pm.\"HIGH\" AS high,\n  pm.\"MEDIUM\" AS medium,\n  pm.\"LOW\" AS low,\n  COALESCE(pm.\"UNASSIGNED_SEVERITY\", 0) AS unassigned,\n  pm.\"VULNERABILITIES\" AS total_vulns,\n  pm.\"VULNERABLECOMPONENTS\" AS vulnerable_components,\n  pm.\"COMPONENTS\" AS total_components,\n  CASE WHEN COALESCE(pm.\"FINDINGS_TOTAL\", 0) = 0 THEN 0\n    ELSE ROUND(COALESCE(pm.\"FINDINGS_AUDITED\", 0)::numeric / pm.\"FINDINGS_TOTAL\" * 100, 1)\n  END AS audit_progress,\n  pm.\"SUPPRESSED\" AS suppressed\nFROM \"PROJECT\" p\nJOIN \"PROJECTMETRICS\" pm ON pm.\"PROJECT_ID\" = p.\"ID\"\nWHERE p.\"ACTIVE\" = true\n  AND ('${project:raw}' = '$__all' OR p.\"NAME\" || ':' || p.\"VERSION\" IN (${project:sqlstring}))\n  AND pm.\"LAST_OCCURRENCE\" = (\n    SELECT MAX(pm2.\"LAST_OCCURRENCE\") FROM \"PROJECTMETRICS\" pm2 WHERE pm2.\"PROJECT_ID\" = p.\"ID\"\n  )\nORDER BY pm.\"RISKSCORE\" DESC",
        "refId": "A"
      }]
    }
